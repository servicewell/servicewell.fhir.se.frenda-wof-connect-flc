{% comment %}
==========================================================================
Template:     Frenda GetOrganizationBundle
Purpose:      Generates a FHIR SearchSet Bundle with Organizations.
Version:      0.0.1
Author:       Service Well/@marcus.lindblom
Date:         2025-10-21

Context:
  -Clinics from Frenda API

Parameters:

Output:
  - FHIR Bundle resource with:
      - Organizations
==========================================================================
{% endcomment %}
{% assign bundle_id = msg.id | generate_id_input: "Bundle", false | generate_uuid -%}
{% assign full_bundle_id = bundle_id | prepend: "urn:uuid:" -%}
{% assign timestamp = 'now' | date: "yyyy-MM-dd'T'HH:mm:sszzz" -%}

{
  "resourceType": "Bundle",
  "type": "collection",
  "id": "{{ bundle_id }}",
  "timestamp": "{{ timestamp }}",
  "entry": [
    {% for organizationItem in msg -%}
    {
      "fullUrl": "urn:uuid:{{ organizationItem.id }}",
      "resource": {% include "resources/organization", organization: organizationItem %}
    }{% if forloop.last == false %},{% endif %}
    {% endfor -%}
  ]
}