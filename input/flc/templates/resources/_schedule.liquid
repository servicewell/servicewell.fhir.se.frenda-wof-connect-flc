{% comment %}
==========================================================================
Template:     Frenda _schedule
Purpose:      Generates a  schedules.
Version:      0.0.2
Author:       Service Well/@olof.mattsson
Date:         2025-10-30

Context:
  -LM: FrendaClinicTreatments
  -API: /api/clinic/treatments

Parameters:
  root: dataRoot: msg.data.getClinicTreatments, 
  treater: data.getClinicTreatments.treaters (instance)
Output:
      - Schedule resource
==========================================================================
{% endcomment %}
{%- assign scheduleSeed = 'schedule|frenda|' | append: root.clinic.id  | append: '|' | append: treater.id -%}
{%- assign scheduleId   = scheduleSeed | generate_uuid -%}
{% evaluate practionerRoleId using 'id/practitionerrole_id' param_clinicId: root.clinic.id , param_treaterId: treater.id,param_costLocationId: root.clinic.costLocations[0].id -%}   


{
  "resourceType": "Schedule",
  "id": "{{ scheduleId }}",
  "meta": {
    "tag": [
      { "system": "{{wof-connect-codesystem-pms-system}}", "code": "{{ sourceSystem }}" }
    ],
    "profile": [
      "{{wof-connect-profile-schedule}}"
    ]
  },  
  "serviceType": [
    {% assign first = true %}
    {%- for t in root.treatments -%}
      {%- assign hasMatch = false -%}
      {%- for id in t.treaterIds -%}
        {%- if id == treater.id -%}
          {%- assign hasMatch = true -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if hasMatch -%}
        {%- unless first -%},{%- endunless -%}
        {
          "coding": [
            {
              "system": "{{wof-connect-identifiercodesystem-service-type-id}}",
              "code": "{{ t.id }}",
              "display": "{{ t.name }}"
            }            
          ],
          "text": "{{ t.description }}"
        }
        {% assign first = false %}
      {%- endif -%}
    {%- endfor -%}
  ],
  "actor": [
    {
      "reference": "HealthcareService/{{ root.clinic.id }}",
      "display": "{{ root.clinic.name }}"
    },
    {
      "reference": "Practitioner/{{ treater.id }}",
      "display": "{{ treater.name | default: treater.id }}"
    },
    {
      "reference": "PractitionerRole/{{ practionerRoleId }}",
      "display": "{{ treater.name | default: treater.id }}"
    }
  ],
  "planningHorizon": {
    "start": "{{  'now' | date: 'yyyy-MM-dd' }}",
    "end": "{{ root.clinic.searchDateLimit  | date: 'yyyy-MM-dd'}}"
  }
}
