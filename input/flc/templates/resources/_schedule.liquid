{%- assign scheduleSeed = 'schedule|frenda|' | append: root.clinic.id | append: '|' | append: treatment.id | append: '|' | append: treater -%}
{%- assign scheduleId   = scheduleSeed | generate_uuid -%}
{%- assign treaterMatch = root.treaters | where: "id", treater | first -%}
{
  "resourceType": "Schedule",
  "id": "{{ scheduleId }}",
  "serviceType": [
    {
      "coding": [
        {
          {% comment %} System is not conformant with Frenda {% endcomment %}
          "system": "http://portal.wof.purified.link/fhir/CodeSystem/csServiceType",
          "code": "{{ treatment.calendarTreatmentType | downcase | replace: ' ', '-' }}",
          {% comment %} Should be added to conformance {% endcomment %}
          "display": "{{ treatment.name }}"
        }
      ],
      {% comment %} Should be added to conformance {% endcomment %}
      "text": "{{ treatment.name }}"
    }
  ],
  "actor": [
    {
      "reference": "HealthcareService/{{ root.clinic.id }}",
      "display": "{{ root.clinic.name }}"
    },
    {
      {% comment %} For Frenda, PractitionerRole should suffice {% endcomment %}
      "reference": "Practitioner/{{ treater }}",
      "display": "{{ treaterMatch.name | default: treater }}"
    },
    {
      {% comment %} Not applicable for Frenda {% endcomment %}
      "reference": "itbDev-colosseum-opus-sandvika/fhir/Organization/578",
      "display": ""
    },
    {
      "reference": "PractitionerRole/{{ treater }}",
      "display": "{{ treaterMatch.name | default: treater }}"
    }
  ],
  "planningHorizon": {
    {% comment %} Start is not available from Frenda, should we set it to Now? {% endcomment %}
    "end": "{{ root.clinic.searchDateLimit }}"
  }
}