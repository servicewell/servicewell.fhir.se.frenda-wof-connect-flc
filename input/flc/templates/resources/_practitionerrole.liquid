    "profile": [
      "http://portal.wof.purified.link/fhir/StructureDefinition/ITBPractitionerRole/v1"
    ]
  },
  "contained": [
    {
      {%- comment -%} This is not supplied from Frenda, obviously {%- endcomment -%}
