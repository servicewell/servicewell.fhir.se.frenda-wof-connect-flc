{%- comment -%} Resources/_PractitionerRole.liquid (expects: root, treaterId) {%- endcomment -%}
{%- assign treater = root.treaters | where: "id", treaterId | first -%}
{%- capture roleSeed -%}role|frenda|{{ root.clinic.id }}|{{ treaterId }}{%- endcapture -%}
{%- assign roleId = roleSeed | generate_uuid -%}
{%- capture pracSeed -%}prac|frenda|{{ treaterId }}{%- endcapture -%}
{%- assign pracId = pracSeed | generate_uuid -%}

{
