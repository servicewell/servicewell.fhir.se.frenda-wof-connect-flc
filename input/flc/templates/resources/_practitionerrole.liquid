            {
              "extension": [
                {
                  "url": "http://portal.wof.purified.link/fhir/StructureDefinition/extTimingDuration",
                  "valueDecimal": {{ t.duration }}
                }
              ],
              "item": {
                "reference": "ActivityDefinition/{{ t.id }}",
                "display": "{{ t.name }}"
              }
            }
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  ],
