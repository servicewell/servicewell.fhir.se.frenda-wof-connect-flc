{
  "resourceType": "Appointment",
  "id": "{{ appt.id }}",
  "meta": {
    "extension": [
      {
        {% comment %} Not available - make optional {% endcomment %}
        "extension": [
          {
            "url": "created",
            "valueDateTime": "2025-08-25T12:15:35.123+00:00"
          },
          {
            "url": "row-version",
            "valueString": "AAAAAAADS8E="
          }
        ],
        "url": "http://portal.wof.purified.link/fhir/StructureDefinition/extWofMeta"
      }
    ],
    {% comment %} Not available - make optional {% endcomment %}
    "lastUpdated": "2025-08-25T12:16:00+00:00",
    "tag": [
      {
        "system": "http://portal.wof.purified.link/fhir/CodeSystem/csAvailableForCancellation",
        "code": "{% if appt.canAppointmentBeCancelled %}true{% else %}false{% endif %}"
      },
      {
        "system": "http://portal.wof.purified.link/fhir/CodeSystem/csAvailableForReschedule",
        "code": "{% if appt.canAppointmentBeRescheduled %}true{% else %}false{% endif %}"
      }
    ]
  },
  "extension": [
    {
      "url": "http://portal.wof.purified.link/fhir/StructureDefinition/extBookingCommentFromPatient"
    }
  ],
  "identifier": [
    {
      "type": {
        "coding": [
          {
            "code": "bookingId",
            "system": "http://opusdental.purified.link/fhir/CodeSystem/csOpusIdentifier"
          }
        ]
      },
      {% comment %} System is not conformant with Frenda {% endcomment %}
      "system": "[[baseurl]]/frenda/fhir/NamingSystem/nsbookingId",
      "value": "{{ appt.id }}"
    }
  ],
  {% assign apiStatus = appt.status | downcase -%}
  {% case apiStatus -%}
    {% when 'active' -%}
      {% assign fhirStatus = 'booked' -%}
    {% when 'complete' -%}
      {% assign fhirStatus = 'booked' -%}
      {% assign isExpiredByTime = true -%}
    {% when 'cancelled' -%}
      {% assign fhirStatus = 'cancelled' -%}
    {% when 'canceled' -%}
      {% assign fhirStatus = 'cancelled' -%}
    {% else -%}
      {% assign fhirStatus = 'proposed' -%}
  {% endcase -%}
  "status": "{{ fhirStatus }}",
  {% comment %} Should probably be added to conformance {% endcomment %}
  {% if isExpiredByTime -%}
  "statusReason": {
    "coding": [
      {
        "system": "http://portal.wof.purified.link/fhir/CodeSystem/csAppointmentStatusReason",
        "code": "expired-by-time",
        "display": "Expired by time"
      }
    ],
    "text": "Expired by time"
  },
  {% endif -%}
  "serviceType": [
    {
      {% comment %} Not sure on how to define the system {% endcomment %}
      "coding": [
        {
          "system": "http://portal.wof.purified.link/fhir/CodeSystem/csServiceType",
          "code": "{% if appt.treatmentType %}{{ appt.treatmentType | downcase | replace: ' ', '-' }}{% elsif appt.treatment.calendarTreatmentType %}{{ appt.treatment.calendarTreatmentType | downcase | replace: ' ', '-' }}{% else %}itb-not-defined{% endif %}",
          "display": "{{ appt.treatment.name | default: 'Bokat besök online' }}"
        }
      ],
      "text": "{{ appt.treatment.name | default: 'Bokat besök online' }}"
    }
  ],
  {% comment %} Can be added to our conformance {% endcomment %}
  "description": "{{ appt.reason | default: '' }}",
  "start": "{{ appt.start }}",
  "end": "{{ appt.start | date_add: appt.duration, 'minute' }}",
  "participant": [
    {
      "actor": {
        {% comment %}
            Either we keep the non-fhir-conformant way below (atleast for an external non-fhir api), 
            or we actually add the resources to the bundle and reference them as contained (best practice)
        {% endcomment %}
        "reference": "HealthcareService/{{ appt.clinic.id }}",
        "display": "{{ appt.clinic.name }}"
      },
      "status": "accepted"
    },
    {
      {% comment %} Patient comes from the accesstoken in Frenda {% endcomment %}
      "actor": {
        "reference": "Patient/"
      },
      "status": "accepted"
    },
    {
      "type": [
        {
          "coding": [
            {
              "code": "PPRF",
              "system": "http://terminology.hl7.org/CodeSystem/v3-ParticipationType"
            }
          ],
          "text": "PrimaryPerformer"
        }
      ],
      "actor": {
        "reference": "PractitionerRole/{{ appt.treater.id }}",
        "display": "{{ appt.treater.name }}"
      },
      "status": "accepted"
    },
    {% comment %} No device in Frenda, make optional {% endcomment %}
    {
      "actor": {
        "reference": "Device/17"
      },
      "status": "accepted"
    }
  ]
}
